# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&appName=<appName>

# Server Configuration (Render sẽ tự động gán PORT)
PORT=8080

# JWT Secrets (dùng chuỗi ngẫu nhiên dài cho production)
ACCESS_TOKEN_SECRET=your_super_secure_access_token_secret_here
REFRESH_TOKEN_SECRET=your_super_secure_refresh_token_secret_here

# CORS Origin (điền URL frontend khi deploy)
CORS_ORIGIN=https://your-frontend-url.com
